&control
    calculation = 'relax',
    prefix = 'h2o_relax',
    pseudo_dir   = '/home/faust/qe-7.0/pseudo/',
    outdir = './tmp/',
    verbosity = 'high',
    tprnfor = .true.,
    forc_conv_thr = 1.0d-4,
    etot_conv_thr = 1.0d-5,
    nstep = 50
/
&system
    ibrav = 1,
    celldm(1) = 20.0,
    nat = 3,
    ntyp = 2,
    ecutwfc = 40.0,
    ecutrho = 320.0,
    occupations = 'fixed'
/
&electrons
    conv_thr = 1.0d-8,
    mixing_beta = 0.7
/
&ions
    ion_dynamics = 'bfgs'
/
ATOMIC_SPECIES
 O   15.999  O.pbe-van_ak.UPF
 H    1.008  H.pbe-van_ak.UPF

ATOMIC_POSITIONS (angstrom)
 O   0.000   0.000   0.117
 H   0.000   0.757  -0.469
 H   0.000  -0.757  -0.469

K_POINTS (gamma)
