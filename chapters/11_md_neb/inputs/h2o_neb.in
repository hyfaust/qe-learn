BEGIN
BEGIN_PATH_INPUT
&PATH
  restart_mode   = 'from_scratch'
  string_method  = 'neb'
  nstep_path     = 2
  ds             = 2.D0
  opt_scheme     = 'broyden'
  num_of_images  = 3
  k_max          = 0.3D0
  k_min          = 0.2D0
  CI_scheme      = 'auto'
  path_thr       = 0.05D0
/
END_PATH_INPUT
BEGIN_ENGINE_INPUT
&CONTROL
  prefix     = 'h2o_neb'
  outdir     = './tmp/'
  pseudo_dir   = '/home/faust/qe-7.0/pseudo/'
/

&SYSTEM
  ibrav     = 0
  nat       = 3
  ntyp      = 2
  ecutwfc   = 40.0
  ecutrho   = 320.0
  nosym     = .TRUE.
/

&ELECTRONS
  conv_thr    = 1.D-8
  mixing_beta = 0.7
/

&IONS
/

ATOMIC_SPECIES
 O  15.999  O.pbe-van_ak.UPF
 H   1.008  H.pbe-van_ak.UPF

K_POINTS { gamma }

CELL_PARAMETERS { angstrom }
  15.0   0.0   0.0
   0.0  15.0   0.0
   0.0   0.0  15.0

BEGIN_POSITIONS
FIRST_IMAGE
ATOMIC_POSITIONS { angstrom }
 O   0.000000   0.000000   0.117369
 H   0.000000   0.756950  -0.469476
 H   0.000000  -0.756950  -0.469476
LAST_IMAGE
ATOMIC_POSITIONS { angstrom }
 O   0.000000   0.000000   0.117369
 H   0.756950   0.000000  -0.469476
 H  -0.756950   0.000000  -0.469476
END_POSITIONS

END_ENGINE_INPUT
END
