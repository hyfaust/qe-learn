&control
    calculation  = 'nscf'
    restart_mode = 'from_scratch'
    prefix       = 'silicon'
    pseudo_dir   = '/home/faust/qe-7.0/pseudo/'
    outdir       = './tmp/'
/
&system
    ibrav    = 2
    celldm(1)= 10.20
    nat      = 2
    ntyp     = 1
    ecutwfc  = 18.0
    nbnd     = 8
/
&electrons
    diagonalization = 'david'
    conv_thr        = 1.0d-8
/
ATOMIC_SPECIES
  Si  28.086  Si.pz-vbc.UPF

ATOMIC_POSITIONS alat
  Si  0.00  0.00  0.00
  Si  0.25  0.25  0.25

K_POINTS automatic
  12  12  12  0  0  0
