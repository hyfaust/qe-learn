 &control
    calculation = 'scf',
    restart_mode = 'from_scratch',
    prefix = 'fe_fm',
    pseudo_dir   = '/home/faust/qe-7.0/pseudo/',
    outdir = './tmp/',
 /
 &system
    ibrav = 3,
    celldm(1) = 5.40,
    nat = 1,
    ntyp = 1,
    ecutwfc = 25.0,
    ecutrho = 250.0,
    nspin = 2,
    starting_magnetization(1) = 0.5,
    occupations = 'smearing',
    smearing = 'mv',
    degauss = 0.02,
 /
 &electrons
    conv_thr = 1.0d-8,
    mixing_beta = 0.3,
 /
ATOMIC_SPECIES
 Fe  55.845  Fe.pz-nd-rrkjus.UPF
ATOMIC_POSITIONS alat
 Fe  0.0  0.0  0.0
K_POINTS automatic
 10  10  10  1  1  1
