&CONTROL
  calculation  = 'bands'
  prefix       = 'sic'
  outdir       = './tmp'
  pseudo_dir   = '/home/faust/qe-7.0/pseudo/'
  restart_mode = 'from_scratch'
/

&SYSTEM
  ibrav     = 2
  celldm(1) = 8.24           ! SiC 晶格参数 (Bohr) ≈ 4.36 Å
  nat       = 2
  ntyp      = 2
  ecutwfc   = 30.0
  nbnd      = 12
  occupations = 'fixed'
/

&ELECTRONS
  conv_thr    = 1.0d-8
  mixing_beta = 0.7
  electron_maxstep = 200
/

ATOMIC_SPECIES
 Si  28.086  Si.pz-vbc.UPF
 C   12.011  C.pz-rrkjus.UPF

ATOMIC_POSITIONS crystal
 Si  0.00  0.00  0.00
 C   0.25  0.25  0.25

K_POINTS crystal_b
5
  0.500  0.500  0.500  20  ! L
  0.000  0.000  0.000  30  ! Gamma
  0.500  0.500  0.000  20  ! X
  0.375  0.375  0.750  20  ! K
  0.000  0.000  0.000   1  ! Gamma
