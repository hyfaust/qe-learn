#------------------------------------------------------------------------------
# Si SCF 计算 — 为 epsilon.x 介电函数计算提供波函数和电荷密度
# 运行此文件后，再运行 si_scf.nscf.in，最后运行 si_epsilon.in
#------------------------------------------------------------------------------
&CONTROL
  calculation = 'scf'
  prefix      = 'silicon'
  pseudo_dir   = '/home/faust/qe-7.0/pseudo/'
  outdir      = './tmp/'
/

&SYSTEM
  ibrav     = 2
  celldm(1) = 10.2612       ! Si 晶格参数 (Bohr)
  nat       = 2
  ntyp      = 1
  ecutwfc   = 30.0
  occupations = 'fixed'
/

&ELECTRONS
  conv_thr    = 1.0D-10
  mixing_beta = 0.7
/

ATOMIC_SPECIES
  Si  28.086  Si.pz-vbc.UPF

ATOMIC_POSITIONS {crystal}
  Si  0.00  0.00  0.00
  Si  0.25  0.25  0.25

K_POINTS {automatic}
  8  8  8  0  0  0
