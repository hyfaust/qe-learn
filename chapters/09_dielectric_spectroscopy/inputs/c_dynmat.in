###############################################################################
#  金刚石 — dynmat.x 后处理：提取 IR 和 Raman 强度
#
#  物理背景：
#    dynmat.x 读取动力学矩阵文件，对角化得到声子频率和本征矢
#    同时计算 IR 强度（基于 Born 有效电荷）和 Raman 强度（基于拉曼张量）
#    asr='simple' 施加简单声学求和规则，消除数值误差导致的非零声学频率
###############################################################################

 &input
  fildyn  = 'C.dynG'       ! 输入动力学矩阵文件（来自 ph.x）
  filout  = 'C.dyn.out'    ! 输出本征值/本征矢文件
  asr     = 'simple'       ! 声学求和规则
 /
