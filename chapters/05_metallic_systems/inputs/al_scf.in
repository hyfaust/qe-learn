# Al FCC — SCF 基态计算
# Marzari-Vanderbilt (cold) smearing
# 参考：PW/examples/example01

 &control
    calculation  = 'scf'
    restart_mode = 'from_scratch'
    prefix       = 'al'
    pseudo_dir   = '/home/faust/qe-7.0/pseudo/'
    outdir       = './tmp/'
    tstress      = .true.
    tprnfor      = .true.
 /

 &system
    ibrav        = 2
    celldm(1)    = 7.50
    nat          = 1
    ntyp         = 1
    ecutwfc      = 15.0
    occupations  = 'smearing'
    smearing     = 'marzari-vanderbilt'
    degauss      = 0.05
 /

 &electrons
    diagonalization = 'david'
    mixing_beta     = 0.7
    conv_thr        = 1.0d-8
 /

ATOMIC_SPECIES
 Al  26.98  Al.pz-vbc.UPF

ATOMIC_POSITIONS alat
 Al  0.00  0.00  0.00

K_POINTS automatic
 8 8 8 0 0 0
