###############################################################################
#  硅（Si）晶体 — 自洽场（SCF）计算输入文件
#  使用量子 ESPRESSO 的 pw.x 程序
#  
#  物理背景：
#    硅为金刚石结构，空间群 Fd-3m（No. 227），
#    晶格常数 a = 5.43 Å，每个原胞含 2 个 Si 原子。
#    本例使用 PBE 泛函 + GBRV 赝势进行 SCF 计算。
###############################################################################

# ========================================
# CONTROL Namelist — 控制计算类型和 I/O
# ========================================
&CONTROL
  calculation  = 'scf'         ! 计算类型：自洽场（self-consistent field）
  prefix       = 'si'          ! 输出文件前缀，所有临时文件以 'si' 命名
  pseudo_dir   = '/home/faust/qe-7.0/pseudo/'          ! 赝势文件所在目录（请根据实际路径修改）
  outdir       = './tmp/'      ! 临时文件输出目录（波函数、电荷密度等）
  verbosity    = 'high'        ! 输出详细程度，'high' 便于学习和调试
  tprnfor      = .TRUE.        ! 打印原子受力（结构优化时必须）
  tstress      = .TRUE.        ! 打印应力张量（晶格优化时必须）
  etot_conv_thr = 1.0D-8       ! 总能量收敛阈值（Ry），SCF 默认为 1e-4
  forc_conv_thr = 1.0D-4       ! 力收敛阈值（Ry/Bohr），本例 SCF 中不起作用
/

# ========================================
# SYSTEM Namelist — 体系的物理参数
# ========================================
&SYSTEM
  ibrav        = 2              ! Bravais 格子编号：2 = 面心立方（fcc）
  celldm(1)    = 10.2612        ! 晶格参数 a，单位 Bohr（= 5.43 Å）
                                ! 换算：a(Bohr) = a(Å) / 0.529177 = 5.43 / 0.529177 ≈ 10.2612
  nat          = 2              ! 原子总数：金刚石结构每个原胞 2 个原子
  ntyp         = 1              ! 原子种类数：只有一种元素 Si

  ecutwfc      = 30.0           ! 波函数平面波截断能，单位 Ry（= 408.15 eV）
                                ! 提示：应进行收敛测试确定合适的截断能
  ecutrho      = 240.0          ! 电荷密度截断能，单位 Ry
                                ! 对范数守恒赝势，通常 ecutrho = 4 * ecutwfc
                                ! 对超软赝势（如 GBRV），需要更大的 ecutrho

  occupations  = 'fixed'        ! 占据方案：'fixed' 适用于绝缘体/半导体
                                ! Si 是半导体（带隙 ~1.1 eV），用固定占据即可
                                ! 金属体系应设为 'smearing'
  input_dft    = 'PBE'          ! 指定交换关联泛函（覆盖赝势中内置的泛函）
/

# ========================================
# ELECTRONS Namelist — 电子自洽迭代参数
# ========================================
&ELECTRONS
  electron_maxstep = 100        ! 最大 SCF 迭代步数
  conv_thr         = 1.0D-10    ! SCF 收敛阈值（Rydberg）
                                 ! 当连续两次迭代的 |ΔE| < conv_thr 时认为收敛
  mixing_mode      = 'plain'    ! 电荷密度混合方式：'plain' = 简单线性混合
  mixing_beta      = 0.7        ! 线性混合参数 β（0 < β ≤ 1）
                                 ! ρ_new = β * ρ_out + (1-β) * ρ_in
                                 ! β 越大收敛越快，但可能振荡；金属体系建议 0.3-0.5
  mixing_ndim      = 8          ! 密度混合使用的子空间维数（历史向量数）
  diagonalization  = 'david'    ! 对角化算法：'david'（Davidson），适合中小体系
                                 ! 大体系可用 'cg'（共轭梯度）
/

# ========================================
# ATOMIC_SPECIES Card — 原子种类定义
# ========================================
# 格式：标签  质量(amu)  赝势文件名
# 质量用于 MD 和声子计算，SCF 中数值不影响结果但不可省略
ATOMIC_SPECIES
  Si  28.086  Si.pz-vbc.UPF

# ========================================
# ATOMIC_POSITIONS Card — 原子坐标
# ========================================
# 使用晶体坐标（crystal），以晶格矢量为基
# 金刚石结构的两个基矢原子位于 (0,0,0) 和 (1/4, 1/4, 1/4)
# 即：Si1 在原点，Si2 在体对角线的 1/4 处
ATOMIC_POSITIONS {crystal}
  Si   0.000000000   0.000000000   0.000000000
  Si   0.250000000   0.250000000   0.250000000

# ========================================
# K_POINTS Card — k 点网格
# ========================================
# {automatic}：自动生成 Gamma 中心的 Monkhorst-Pack 网格
# 格式：nk1 nk2 nk3  sk1 sk2 sk3
#   nk1-nk3：三个方向的 k 点数
#   sk1-sk3：位移，0 = Gamma 中心，1 = Monkhorst-Pack（非 Gamma）
# 硅为 fcc 结构，4x4x4 网格通常足够精确
# 提示：应进行 k 点收敛测试
K_POINTS {automatic}
  4  4  4  0  0  0
