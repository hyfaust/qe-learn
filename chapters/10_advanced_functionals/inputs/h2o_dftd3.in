#------------------------------------------------------------------------------
# 水分子 H2O DFT-D3 色散修正计算
# 方法：PBE + DFT-D3，单分子在大盒子中
#------------------------------------------------------------------------------
&control
    calculation = 'scf'
    restart_mode = 'from_scratch'
    prefix = 'h2o_d3'
    pseudo_dir   = '/home/faust/qe-7.0/pseudo/'
    outdir = './tmp/'
 /
 &system
    ibrav = 1
    celldm(1) = 15.0
    nat = 3
    ntyp = 2
    ecutwfc = 40.0
    ecutrho = 320.0
    vdw_corr = 'dft-d3'
 /
 &electrons
    conv_thr = 1.0d-8
 /
ATOMIC_SPECIES
 O  15.999  O.pbe-van_ak.UPF
 H   1.008  H.pbe-van_ak.UPF
ATOMIC_POSITIONS {angstrom}
 O   0.000000   0.000000   0.117370
 H   0.000000   0.756950  -0.469480
 H   0.000000  -0.756950  -0.469480
K_POINTS {automatic}
 1 1 1 0 0 0
