#------------------------------------------------------------------------------
# Si HSE06 杂化泛函 SCF 计算
# 方法：HSE06 (nqx=2)，使用 gygi-baldereschi 发散处理
# 参考：QE PW/examples/EXX_example/
#------------------------------------------------------------------------------
 &control
    calculation = 'scf'
    restart_mode = 'from_scratch'
    prefix = 'si_hse'
    pseudo_dir   = '/home/faust/qe-7.0/pseudo/'
    outdir = './tmp/'
 /
 &system
    ibrav = 2
    celldm(1) = 10.26
    nat = 2
    ntyp = 1
    ecutwfc = 40.0
    nbnd = 8
    input_dft = 'hse'
    nqx1 = 2
    nqx2 = 2
    nqx3 = 2
    exx_fraction = 0.25
    screening_parameter = 0.208
    exxdiv_treatment = 'gygi-baldereschi'
    x_gamma_extrapolation = .true.
 /
 &electrons
    conv_thr = 1.0d-8
    mixing_beta = 0.7
 /
ATOMIC_SPECIES
 Si  28.086  Si.pz-vbc.UPF
ATOMIC_POSITIONS {alat}
 Si  0.00  0.00  0.00
 Si  0.25  0.25  0.25
K_POINTS {automatic}
 4 4 4 0 0 0
