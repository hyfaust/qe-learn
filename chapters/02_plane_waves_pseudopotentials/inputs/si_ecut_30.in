&control
    calculation = 'scf',
    prefix = 'si',
    pseudo_dir   = '/home/faust/qe-7.0/pseudo/',
    outdir = './tmp/',
    verbosity = 'high'
/
&system
    ibrav = 2,
    celldm(1) = 10.20,
    nat = 2,
    ntyp = 1,
    ecutwfc = 30.0,
    ecutrho = 240.0,
    occupations = 'fixed'
/
&electrons
    conv_thr = 1.0d-8,
    mixing_beta = 0.7
/
ATOMIC_SPECIES
 Si  28.086  Si.pz-vbc.UPF

ATOMIC_POSITIONS (alat)
 Si  0.00  0.00  0.00
 Si  0.25  0.25  0.25

K_POINTS (automatic)
 6 6 6 0 0 0
